LUXFLOW_ENV=development
LUXFLOW_ASSETS_DIR=assets
LUXFLOW_OUTPUT_ROOT=assets/outputs
LUXFLOW_CATALOG_PATH=assets/catalog/sample_catalog.json
LUXFLOW_DATABASE_URL=sqlite:///./luxflow.db
LUXFLOW_ENABLE_HOSTED_FALLBACK=false

# Optional real hero-still generation. Disabled by default.
# Install optional dependencies with: pip install -e ".[dev,generation]"
# Torch installation can be platform-sensitive; consult official PyTorch instructions if needed.
LUXFLOW_ENABLE_REAL_IMAGE_GENERATION=false
LUXFLOW_IMAGE_GENERATION_BACKEND=diffusers
LUXFLOW_IMAGE_MODEL_ID=black-forest-labs/FLUX.1-schnell
LUXFLOW_IMAGE_DEVICE=auto
LUXFLOW_IMAGE_WIDTH=1024
LUXFLOW_IMAGE_HEIGHT=1024
LUXFLOW_IMAGE_STEPS=4
LUXFLOW_IMAGE_GUIDANCE_SCALE=0.0
